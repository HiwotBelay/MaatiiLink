# MaatiiLink — copy to .env (never commit .env)

NODE_ENV=development
APP_URL=http://localhost:3000

# Optional: override package version on /api/health (Phase 6)
# RELEASE_VERSION=1.0.0

# Neon PostgreSQL — get both strings from Neon dashboard
# Local dev: use DIRECT (no "-pooler" in hostname) for DATABASE_URL + DIRECT_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
# Vercel/production: pooled DATABASE_URL + direct DIRECT_URL, add &pgbouncer=true&connection_limit=1 to pooled

# Session — use a long random string (openssl rand -base64 32)
SESSION_SECRET=generate-a-long-random-secret

# Optional: local Docker Postgres instead of Neon (see docker-compose.yml)
# DATABASE_URL=postgresql://maatiilink:maatiilink_dev@localhost:5432/maatiilink

# Email notifications (Sprint 3 — optional for local dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_FROM=maatiilink@coopbank.local
# SUPERVISOR_NOTIFY_EMAIL=supervisor@coopbank.local,ops@coopbank.local
