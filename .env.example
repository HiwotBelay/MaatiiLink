# MaatiiLink — copy to .env (never commit .env)

NODE_ENV=development
APP_URL=http://localhost:3000

# Neon PostgreSQL (recommended for team dev — get URL from Neon dashboard)
# Use the *pooled* connection string for serverless / Next.js
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Session — use a long random string (openssl rand -base64 32)
SESSION_SECRET=generate-a-long-random-secret

# Optional: local Docker Postgres instead of Neon (see docker-compose.yml)
# DATABASE_URL=postgresql://maatiilink:maatiilink_dev@localhost:5432/maatiilink
